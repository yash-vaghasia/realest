# =============================================================================
# Realest — environment template
# Copy to .env (do NOT commit). Vercel pulls these from project env config in prod.
# =============================================================================

# ---- Database (Supabase Postgres, Mumbai region) ----
# Pooled (Supavisor, transaction mode, port 6543) — used by app runtime.
DATABASE_URL="postgresql://postgres.<project>:<password>@aws-0-ap-south-1.pooler.supabase.com:6543/postgres"
# Direct (port 5432) — ONLY for migrations. Required by `pnpm payload migrate`.
DIRECT_DATABASE_URL="postgresql://postgres.<project>:<password>@aws-0-ap-south-1.pooler.supabase.com:5432/postgres"

# ---- Payload ----
# Long random string. Used to sign auth tokens. Rotate via Vercel env if leaked.
PAYLOAD_SECRET="change-me-to-a-long-random-string"

# ---- Media (Cloudflare R2, S3-compatible) ----
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET="realest-media"
# R2 S3 endpoint, e.g. https://<account_id>.r2.cloudflarestorage.com
R2_ENDPOINT=""
# Public-read base URL used for serving media in the browser, e.g.
# https://media.realest.co.in   or   https://pub-<id>.r2.dev
R2_PUBLIC_BASE_URL=""

# ---- Email (Resend) ----
RESEND_API_KEY=""
LEAD_NOTIFICATION_EMAIL="leads@realest.co.in"

# ---- Public site URL ----
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# ---- Optional: MahaRERA agent registration ----
# When set, footer disclaimer line renders. When unset, the line is hidden.
MAHARERA_AGENT_REG_NO=""
